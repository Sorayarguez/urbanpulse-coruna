# ------------------------------------------------------------
# UrbanPulse Coruna - FIWARE NGSI-LD Base Environment
# ------------------------------------------------------------
# Versions
MONGO_VERSION=4.4
CRATE_VERSION=latest
QUANTUMLEAP_VERSION=latest
GRAFANA_VERSION=latest

# Exposed host ports
MONGO_DB_PORT=27018
ORION_LD_PORT=1027
MQTT_PORT=1883
IOTA_NORTH_PORT=4041
IOTA_HTTP_PORT=7896
IOTA_NORTH_PORT_LD=4042
IOTA_HTTP_PORT_LD=7897
CRATE_HTTP_PORT=4200
CRATE_PSQL_PORT=5432
QUANTUMLEAP_PORT=8668
GRAFANA_PORT=3000

# Grafana credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Internal URLs for scripts
ORION_BASE_URL=http://localhost:1027
QUANTUMLEAP_BASE_URL=http://localhost:8668
QL_NOTIFY_URL=http://quantumleap:8668/v2/notify

# Healthcheck tuning
HEALTHCHECK_TIMEOUT=5
HEALTHCHECK_RETRIES=10
